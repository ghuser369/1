def parity(s):
    s = [x for x in s if x != 0]
    return sum(s[i] > s[j] for i in range(len(s))
               for j in range(i+1, len(s))) % 2

a = list(map(int, input("Enter State A(1-9): ").split()))
b = list(map(int, input("Enter State B(1-9): ").split()))

print("Result: TRUE - They are in the SAME disjoint set (reachable from one another" if parity(a) == parity(b)
      else "Result: FALSE - They are in DIFFERENT disjoint sets (impossible to reach)")
